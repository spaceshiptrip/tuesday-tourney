# Phase 1 — these values are set directly in app.js and apps-script/Code.gs
# (no build step in vanilla HTML, so .env is not read at runtime)
APPS_SCRIPT_URL=your_deployed_apps_script_web_app_url
SHEET_ID=your_google_sheet_id

# Phase 2 — Vite reads VITE_ prefixed vars at build time
# Copy this file to .env and fill in values (never commit .env)
VITE_APPS_SCRIPT_URL=your_deployed_apps_script_web_app_url
VITE_SHEET_ID=your_google_sheet_id
